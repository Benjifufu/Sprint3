# =============================================================================
# .env.example - copialo a .env y completa los valores
# =============================================================================

# --- Django ---
DEBUG=True
SECRET_KEY=cambia-esto-en-produccion-por-uno-random-largo
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de datos accounts (usuarios, registros de auditoria) ---
DB_NAME_DEFAULT=accounts_db
DB_USER=biteco_user
DB_PASSWORD=biteco_pass
DB_HOST_DEFAULT=localhost
DB_PORT=5432

# --- Base de datos monitoring (consumo cloud, facturas, reportes) ---
DB_NAME_MONITORING=monitoring_db
DB_HOST_MONITORING_PRIMARY=localhost
# Para desarrollo local, la replica = el primary. En AWS cambian.
DB_HOST_MONITORING_REPLICA=localhost

# --- Auth0 (ASR-01) ---
# Crear tenant + Application + API en https://manage.auth0.com
AUTH0_DOMAIN=biteco-dev.us.auth0.com
AUTH0_CLIENT_ID=tu-client-id-de-Auth0
AUTH0_CLIENT_SECRET=tu-client-secret-de-Auth0
